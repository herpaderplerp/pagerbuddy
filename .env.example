DATABASE_URL=postgresql+psycopg://pagerbuddy:pagerbuddy@db:5432/pagerbuddy
PUBLIC_BASE_URL=https://example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TRIAL_ALLOWED_NUMBER=
TWILIO_VALIDATE_REQUESTS=true

# Database-overridable runtime defaults:
# The admin dashboard can override only these `.env` keys:
# INBOUND_CALLER_WHITELIST_ENABLED, INBOUND_CALLER_WHITELIST_NUMBERS,
# INCIDENT_ACTION_TOKEN_TTL_SECONDS, ADMIN_ALERT_EMAILS,
# LOCAL_TRANSCRIPTION_ENABLED, LOCAL_TRANSCRIPTION_MODEL,
# LOCAL_TRANSCRIPTION_DEVICE, LOCAL_TRANSCRIPTION_COMPUTE_TYPE.
# Once a row exists in the `app_settings` table, the database value wins on
# container restart and changing the matching `.env` value has no effect unless
# the DB override is removed or the database is recreated.
INBOUND_CALLER_WHITELIST_ENABLED=false
INBOUND_CALLER_WHITELIST_NUMBERS=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@pagerbuddy.local
INCIDENT_ACTION_TOKEN_TTL_SECONDS=86400
STORE_RECORDINGS_LOCALLY=false
RECORDING_STORAGE_DIR=/app/recordings
LOCAL_TRANSCRIPTION_ENABLED=true
LOCAL_TRANSCRIPTION_MODEL=base.en
LOCAL_TRANSCRIPTION_DEVICE=cpu
LOCAL_TRANSCRIPTION_COMPUTE_TYPE=int8
ADMIN_ALERT_EMAILS=
